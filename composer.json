{
    "name": "spipu/ui-bundle",
    "type": "symfony-bundle",
    "description": "Spipu User Interface Bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Laurent Minguet",
            "email": "contact@minguet.fr"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-zip": "*",
        "doctrine/orm": "^3.0",
        "symfony/framework-bundle": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/http-kernel": "^7.4",
        "spipu/core-bundle":   "^5.0",
        "twbs/bootstrap":      "^5.0"
    },
    "autoload": {
